# --- Required ---
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# --- Optional ---
# Your chat id(s) to auto-subscribe on startup (comma-separated).
# DM @userinfobot on Telegram to find your numeric chat id.
TELEGRAM_CHAT_ID=

# Alert tuning (defaults shown)
FDV_INCREMENT=25_000_000
COOLDOWN_SECONDS=3600
POLL_INTERVAL_SECONDS=60

# Data sources (defaults shown — usually no need to change)
# OI is combined across all three exchanges below.
COINGECKO_ID=perle
# Optional free CoinGecko demo key (https://www.coingecko.com/en/api) to avoid
# 429 rate limits on shared cloud IPs. Leave blank to use the public endpoint.
COINGECKO_API_KEY=
# Max supply used to derive FDV if CoinGecko is unavailable.
MAX_SUPPLY=1000000000
BINANCE_SYMBOL=PRLUSDT
BYBIT_SYMBOL=PRLUSDT
BITGET_SYMBOL=PRLUSDT
BITGET_PRODUCT_TYPE=usdt-futures

# Where to persist subscribers + alert state
STATE_FILE=state.json
